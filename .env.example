# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.
# Cloudflare Registrar or Namecheap for domain purchase.

# ─── Application ───────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_URL=http://localhost:3000        # https://app.onksolutions.in in prod
APP_SECRET=change-me-min-32-chars

# ─── Database ──────────────────────────────────────────────────
# Supabase — keys must be prefixed NEXT_PUBLIC_ so the browser SDK can read them.
# The service role key stays server-only (no NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Backend: Cloudflare Workers ───────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ─── File Storage: Cloudflare R2 ───────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=onk-storage
R2_PUBLIC_URL=https://storage.onksolutions.in

# ─── Email: Resend ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@onksolutions.in

# ─── Payments ──────────────────────────────────────────────────
# Razorpay (India)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Dodo Payments (alternative)
# DODO_API_KEY=your-dodo-key

# ─── Error Tracking: Sentry ────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-auth-token

# ─── Analytics: PostHog ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Background Jobs: Inngest ──────────────────────────────────
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# ─── Developer Super-Admin ─────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@onksolutions.in
SUPER_ADMIN_SECRET=change-me-strong-secret
